# Envio de e-mail do formulário de contato (SMTP da Hostinger).
# Copie este arquivo para `.env.local` e preencha com os dados reais.
# IMPORTANTE: nunca faça commit do `.env.local` (já está no .gitignore).

# Servidor SMTP da Hostinger
SMTP_HOST=smtp.hostinger.com
# 465 = SSL (recomendado) | 587 = STARTTLS
SMTP_PORT=465

# Caixa de e-mail criada no painel da Hostinger (autenticação).
# O "from" do e-mail usa esta caixa.
SMTP_USER=contato@evoluke.com.br
SMTP_PASS=sua_senha_de_email_aqui

# Para onde os contatos do site são enviados.
# Opcional — se vazio, usa SMTP_USER.
CONTACT_TO=contato@evoluke.com.br

# Remetente exibido. Opcional — se vazio, usa SMTP_USER.
# Deve ser a mesma caixa autenticada (a Hostinger bloqueia spoofing).
CONTACT_FROM=contato@evoluke.com.br

# -----------------------------------------------------------------------------
# Blog — token de criação de posts via API
# -----------------------------------------------------------------------------
# Protege POST /api/blog e DELETE /api/blog/:slug.
# A chamada externa deve enviar:  Authorization: Bearer <BLOG_API_TOKEN>
# Gere um token forte (32+ bytes), por exemplo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
BLOG_API_TOKEN=troque_por_um_token_aleatorio_de_32_caracteres_ou_mais
